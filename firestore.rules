rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PORTFOLIO ARCHITECTURE SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * This ruleset implements a dual-layered security model:
     * 1. Path-Based Ownership: User-specific data (Profiles, Projects, Experiences) is nested 
     *    under `/users/{userId}`. Authorization is derived directly from the path.
     * 2. Public Accessibility: Portfolio content is publicly readable.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Allow public to find the owner profile
      allow get, list: if true;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for SocialMediaLink sub-collection.
       */
      match /socialMediaLinks/{linkId} {
        allow get, list: if true;
        allow create: if isOwner(userId) && request.resource.data.userProfileId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userProfileId == resource.data.userProfileId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for Project case studies.
       */
      match /projects/{projectId} {
        allow get, list: if true;
        allow create: if isOwner(userId);
        allow update, delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for Professional Experience.
       */
      match /experiences/{experienceId} {
        allow get, list: if true;
        allow create: if isOwner(userId);
        allow update, delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for Technical Blog Posts.
       */
      match /blogPosts/{blogPostId} {
        allow get, list: if true;
        allow create: if isOwner(userId) && request.resource.data.userProfileId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userProfileId == resource.data.userProfileId;
        allow delete: if isExistingOwner(userId);
      }
    }

    match /technologies/{technologyId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /serviceOfferings/{serviceOfferingId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /tags/{tagId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get: if isOwner(adminId);
      allow list: if false;
      allow create, update, delete: if false; 
    }
  }
}
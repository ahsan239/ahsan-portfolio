
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents the portfolio owner's profile and global website settings.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "headline": { "type": "string" },
        "professionalHeadshotUrl": { "type": "string", "format": "uri" },
        "bio": { "type": "string" },
        "resumeUrl": { "type": "string", "format": "uri" },
        "contactEmail": { "type": "string", "format": "email" },
        "calendlyLink": { "type": "string", "format": "uri" }
      },
      "required": ["id", "name", "headline", "contactEmail"]
    },
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "description": "Represents a detailed software project case study.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "slug": { "type": "string" },
        "problem": { "type": "string" },
        "solution": { "type": "string" },
        "roiMetric": { "type": "string" },
        "businessImpact": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "techStack": { "type": "array", "items": { "type": "string" } },
        "architecture": { "type": "string" },
        "codeSnippet": { "type": "string" },
        "order": { "type": "number" },
        "projectLink": { "type": "string", "format": "uri" },
        "githubLink": { "type": "string", "format": "uri" }
      },
      "required": ["title", "slug", "description", "techStack", "projectLink", "imageUrl"]
    },
    "Experience": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Experience",
      "type": "object",
      "description": "Represents professional work history.",
      "properties": {
        "id": { "type": "string" },
        "company": { "type": "string" },
        "role": { "type": "string" },
        "period": { "type": "string" },
        "desc": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["company", "role", "period", "desc"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Owner profile."
        }
      },
      {
        "path": "/users/{userId}/projects/{projectId}",
        "definition": {
          "entityName": "Project",
          "schema": { "$ref": "#/backend/entities/Project" },
          "description": "Portfolio projects."
        }
      },
      {
        "path": "/users/{userId}/experiences/{experienceId}",
        "definition": {
          "entityName": "Experience",
          "schema": { "$ref": "#/backend/entities/Experience" },
          "description": "Career history."
        }
      }
    ]
  }
}
